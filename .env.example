# ============================================================================
# CodeDock Root Environment Variables
# ============================================================================
# For Docker Compose and root-level configuration
# ============================================================================

# Docker Compose Project Name
COMPOSE_PROJECT_NAME=codedock

# MongoDB
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=changeme
MONGO_INITDB_DATABASE=codedock

# Backend
BACKEND_PORT=8001

# Frontend
FRONTEND_PORT=3000

# Environment
NODE_ENV=development
