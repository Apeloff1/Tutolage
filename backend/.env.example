# ============================================================================
# CodeDock Backend Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# ============================================================================

# Database
# --------
# MongoDB connection string
# Local: mongodb://localhost:27017/codedock
# Atlas: mongodb+srv://user:password@cluster.mongodb.net/codedock
MONGO_URL=mongodb://localhost:27017/codedock

# AI/LLM Integration
# ------------------
# Emergent LLM Key (Universal key for OpenAI, Anthropic, Google)
# Get from: Emergent Platform -> Profile -> Universal Key
EMERGENT_LLM_KEY=your_emergent_llm_key_here

# Optional: Direct OpenAI key (if not using Emergent)
# OPENAI_API_KEY=sk-your-openai-key

# Server Configuration
# --------------------
# Host and port for the FastAPI server
HOST=0.0.0.0
PORT=8001

# Environment: development, staging, production
ENVIRONMENT=development

# Debug mode (enables hot reload, verbose logging)
DEBUG=true

# CORS Origins (comma-separated)
# CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ChromaDB Configuration
# ----------------------
# Path for ChromaDB persistent storage
CHROMA_PERSIST_DIR=./chroma_data

# Logging
# -------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Security
# --------
# JWT Secret (generate with: openssl rand -hex 32)
# JWT_SECRET=your-super-secret-jwt-key

# Rate Limiting
# RATE_LIMIT_PER_MINUTE=60
